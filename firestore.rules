rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // 1. User Profile Collection
    match /users/{userId} {
      function isValidUserProfile(data) {
        return data.personality is string && data.personality.size() <= 100
          && data.monthly_budget is number
          && data.keys().hasAll(['personality', 'monthly_budget'])
          && data.keys().size() <= 4; // monthly_budget, personality, updatedAt, maybe some other small fields
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming())
        && (incoming().diff(resource.data).affectedKeys().hasOnly(['personality', 'monthly_budget', 'updatedAt']));
    }

    // 2. Transactions Subcollection
    match /users/{userId}/transactions/{txId} {
      function isValidTransaction(data) {
        return data.id is string
          && data.item is string && data.item.size() <= 100
          && data.category is string && data.category.size() <= 50
          && data.amount is number
          && data.token is string && data.token.size() <= 10
          && data.recipient is string && data.recipient.size() <= 100
          && data.decision is string && data.decision.size() <= 20
          && data.verdict is string && data.verdict.size() <= 50
          && data.timestamp is string;
      }

      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidTransaction(incoming());
    }
  }
}
